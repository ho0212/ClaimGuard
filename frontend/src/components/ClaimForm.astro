---
---

<div class="claim-container">
  <h2>🛡️ ClaimGuard AI Claims Review</h2>
  
  <form id="upload-form" class="upload-form">
    
    <div class="form-group">
      <label for="insurance-type">1. Select Insurance Type</label>
      <select id="insurance-type" name="insurance_type" required>
        <option value="" disabled selected>Select...</option>
        <option value="medical">🏥 Medical Insurance</option>
        <option value="auto">🚗 Auto Insurance - Coming Soon</option>
      </select>
    </div>

    <div id="instruction-box" class="instruction-box hidden">
      <h4 style="margin-top: 0; color: #166534; font-size: 1rem;">Files to Prepare:</h4>
      <ul id="instruction-list" style="margin: 0; padding-left: 1.5rem; color: #15803d; line-height: 1.5;">
        </ul>
    </div>

    <div id="policy-details" class="hidden">
      
      <div class="form-group">
        <label for="company-plan">2. Select Insurance Company and Plan</label>
        <select id="company-plan" name="company_plan" required>
          <option value="" disabled selected>Select...</option>
          
          <optgroup label="Medical Plans">
            <option value="Allianz|OVHC_visitor">Allianz - OVHC for visitor visas (600, 601, 651, and others)</option>
            <option value="Allianz|OVHC_work">Allianz - OVHC for working visas (482, 485, 417, and others)</option>
          </optgroup>
          
          <optgroup label="Auto Plans - Coming Soon" disabled>
            <option value="NA">Coming Soon</option>
          </optgroup>
        </select>
      </div>

      <div class="form-group" style="margin-top: 1rem;">
        <label for="receipt-image">3. Upload Proof Documents (Multiple Selection Allowed)</label>
        <div class="file-input-wrapper">
          <input type="file" id="receipt-image" name="receipt_files" accept="image/*, application/pdf" multiple required />
        </div>
      </div>

      <button type="submit" id="submit-btn" class="submit-btn" style="width: 100%; margin-top: 1rem;">
        Start AI review 🚀
      </button>
    </div>
  </form>

  <div id="loading-indicator" class="hidden">
    <p style="text-align: center; color: #4b5563;">AI is currently comparing the insurance terms online, please wait....</p>
    <div class="spinner"></div>
  </div>

  <div id="result-container" class="result-container hidden">
    <h3>Claims Analysis Report</h3>
    <div class="result-grid">
      <div class="result-item">
        <span class="label">Date of Treatment:</span>
        <span id="res-date" class="value"></span>
      </div>
      <div class="result-item">
        <span class="label">Diagnosis:</span>
        <span id="res-diagnosis" class="value"></span>
      </div>
      <div class="result-item">
        <span class="label">Declared Amount:</span>
        <span id="res-cost" class="value"></span>
      </div>
    </div>
    
    <div class="decision-box">
      <h4>Final Decision</h4>
      <p id="res-decision" class="decision-text" style="white-space: pre-wrap; line-height: 1.6;"></p>
    </div>
    
    <div class="policy-box">
      <h4>Trigger Clause</h4>
      <pre id="res-policy" class="policy-text"></pre>
    </div>
  </div>
</div>

<script>
  // UI element references
  const form = document.getElementById('upload-form');
  const typeSelect = document.getElementById('insurance-type');
  const instructionBox = document.getElementById('instruction-box');
  const instructionList = document.getElementById('instruction-list');
  const policyDetails = document.getElementById('policy-details');
  const submitBtn = document.getElementById('submit-btn');
  const loadingIndicator = document.getElementById('loading-indicator');
  const resultContainer = document.getElementById('result-container');

  // Interactive logic for insurance type selection
  typeSelect.addEventListener('change', (e) => {
    const selectedType = e.target.value;
    
    // Follow up UI elements show/hide logic
    instructionBox.classList.remove('hidden');
    policyDetails.classList.remove('hidden');

    // Dynamically update instructions based on insurance type
    if (selectedType === 'medical') {
      instructionList.innerHTML = `
        <li>📝 <b>Doctors Diagnosis Certificate</b> (Diagnosis Certificate)</li>
        <li>🧾 <b>Medical Receipts</b> (Receipts, multiple allowed)</li>
      `;
    } else if (selectedType === 'auto') {
      instructionList.innerHTML = `
        <li>📸 <b>Photos of Accident Scene</b></li>
        <li>🧾 <b>Repair Shop Quotes/Receipts</b></li>
      `;
    }
  });

  // Form submission logic
  form.addEventListener('submit', async (e) => {
    e.preventDefault(); // Prevent form from refreshing
    
    const fileInput = document.getElementById('receipt-image');
    if (!fileInput.files.length) {
      alert('Please select a receipt!');
      return;
    }

    // Prepare form data (FormData)
    const formData = new FormData();
    for (let i = 0; i < fileInput.files.length; i++) {
      formData.append('receipt_files', fileInput.files[i]);
    }

    // Split the combined value from the dropdown into company and plan
    const combinedValue = document.getElementById('company-plan').value;
    const [selectedCompany, selectedPlan] = combinedValue.split('|');

    // Append additional form data
    formData.append('company', selectedCompany);
    formData.append('plan', selectedPlan);
    formData.append('insurance_type', typeSelect.value);

    // Change UI state to loading
    submitBtn.disabled = true;
    loadingIndicator.classList.remove('hidden');
    resultContainer.classList.add('hidden');

    try {
      // Call the backend API
      const response = await fetch('http://127.0.0.1:8000/api/evaluate-claim', {
        method: 'POST',
        body: formData,
      });

      const data = await response.json();

      if (data.status === 'success') {
        // Load results into the UI
        document.getElementById('res-date').textContent = "Multiple Dates";
        document.getElementById('res-diagnosis').textContent = data.final_diagnosis || 'N/A';
        document.getElementById('res-cost').textContent = `$${data.aggregated_cost || 'N/A'}`;
        document.getElementById('res-policy').textContent = data.policy_matched || 'Relevant policy clause not found.';
        document.getElementById('res-decision').textContent = data.decision_report || 'No decision generated.';

        // Show the result container
        resultContainer.classList.remove('hidden');
      } else {
        alert('Error occurs at the backend:' + (data.message || 'Unknown Error'));
      }
    } catch (error) {
      console.error('API Calling Failed:', error);
      alert('Cannot connect to backend server. Please confirm FastAPI is running!');
    } finally {
      // Reset loading state
      submitBtn.disabled = false;
      loadingIndicator.classList.add('hidden');
    }
  });
</script>

<style>
  /* basic styles */
  .claim-container {
    max-width: 600px;
    margin: 0 auto;
    padding: 2rem;
    font-family: system-ui, sans-serif;
    background: #f9f9fb;
    border-radius: 12px;
    box-shadow: 0 4px 6px rgba(0,0,0,0.05);
  }

  .upload-form {
    display: flex;
    flex-direction: column;
    margin-bottom: 1rem;
  }

  /* form group */
  .form-group {
    display: flex;
    flex-direction: column;
    margin-bottom: 1rem;
  }

  .form-group label {
    font-weight: bold;
    color: #374151;
    margin-bottom: 0.4rem;
  }

  .form-group select {
    padding: 0.75rem;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    font-size: 1rem;
    background-color: white;
  }

  /* Dynamically updated instruction box styles */
  .instruction-box {
    background-color: #f0fdf4;
    border-left: 4px solid #22c55e;
    padding: 1rem 1.5rem;
    margin-bottom: 1.5rem;
    border-radius: 0 8px 8px 0;
  }

  .file-input-wrapper {
    padding: 1.5rem 1rem;
    border: 2px dashed #ccc;
    border-radius: 8px;
    text-align: center;
    background: white;
  }

  .submit-btn {
    padding: 1rem;
    background: #2563eb;
    color: white;
    border: none;
    border-radius: 8px;
    font-size: 1.1rem;
    font-weight: bold;
    cursor: pointer;
    transition: background 0.2s;
  }

  .submit-btn:hover { background: #1d4ed8; }
  .submit-btn:disabled { background: #93c5fd; cursor: not-allowed; }

  .hidden { display: none !important; }

  .result-container {
    background: white;
    padding: 1.5rem;
    border-radius: 8px;
    border: 1px solid #e5e7eb;
    margin-top: 1rem;
  }

  .result-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .result-item {
    display: flex;
    flex-direction: column;
    padding: 0.75rem;
    background: #f3f4f6;
    border-radius: 6px;
  }

  .label { font-size: 0.8rem; color: #6b7280; text-transform: uppercase; }
  .value { font-size: 1.1rem; font-weight: bold; color: #111827; margin-top: 0.25rem;}

  .decision-box {
    padding: 1rem;
    background: #eff6ff;
    border-left: 4px solid #3b82f6;
    margin-bottom: 1rem;
    border-radius: 0 8px 8px 0;
  }

  .policy-box pre {
    background: #1f2937;
    color: #e5e7eb;
    padding: 1rem;
    border-radius: 6px;
    font-size: 0.85rem;
    white-space: pre-wrap;
  }

  /* Loading animation */
  .spinner {
    border: 4px solid rgba(0, 0, 0, 0.1);
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border-left-color: #2563eb;
    animation: spin 1s linear infinite;
    margin: 1rem auto;
  }
  @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
</style>