---
import ClaimForm from '../components/ClaimForm.astro';
---

<html lang="zh-TW">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<title>ClaimGuard AI Smart Claims</title>
		<style>
			body {
				margin: 0;
				padding: 2rem;
				background-color: #f3f4f6;
				min-height: 100vh;
			}
			.header {
				text-align: center;
				margin-bottom: 3rem;
			}
			h1 {
				color: #111827;
				font-size: 2.5rem;
				margin-bottom: 0.5rem;
			}
			p.subtitle {
				color: #6b7280;
				font-size: 1.1rem;
			}
		</style>
	</head>
	<body>
		<div class="header">
			<h1>ClaimGuard AI</h1>
			<p class="subtitle">Enterprise-level AI insurance claims review system</p>
		</div>
		
		<main>
			<ClaimForm />
		</main>
	</body>
</html>