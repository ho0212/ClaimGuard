      animation: flowLine 4s linear infinite;
    }
    
    /* Cards animation */
    @keyframes nodeActivate {
      0%, 100% { transform: translateY(0); box-shadow: 0 1px 2px 0 rgba(0,0,0,0.05); border-color: #e2e8f0; }
      10%, 25% { transform: translateY(-8px); box-shadow: 0 20px 25px -5px rgba(37, 99, 235, 0.2); border-color: #3b82f6; }
    }
    
    /* Icon Colour */
    @keyframes iconActivate {
      0%, 100% { background-color: #f1f5f9; color: #475569; border-color: #ffffff; }
      10%, 25% { background-color: #2563eb; color: #ffffff; border-color: #bfdbfe; }
    }
    
    /* Delay for each node */
    .node-1 { animation: nodeActivate 4s infinite 0s; }
    .icon-1 { animation: iconActivate 4s infinite 0s; }
    
    .node-2 { animation: nodeActivate 4s infinite 1s; }
    .icon-2 { animation: iconActivate 4s infinite 1s; }
    
    .node-3 { animation: nodeActivate 4s infinite 2s; }
    .icon-3 { animation: iconActivate 4s infinite 2s; }
    
    .node-4 { animation: nodeActivate 4s infinite 3s; }
    .icon-4 { animation: iconActivate 4s infinite 3s; }
</style>
