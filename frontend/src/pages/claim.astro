<!DOCTYPE html>
<html class="light" lang="en">
<head>
  <meta charset="utf-8"/>
  <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
  <title>ClaimGuard AI - Enterprise Claim Review</title>
  
  <!-- Tailwind CSS-->
  <script is:inline src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  
  <script is:inline id="tailwind-config">
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          "colors": {
            "background": "#f8f9fb",
            "outline-variant": "#c3c6d6",
            "on-surface": "#191c1e",
            "on-surface-variant": "#434654",
            "primary-container": "#0052cc",
            "primary": "#003d9b"
          }
        }
      }
    }
  </script>

  <style>
    body { font-family: 'Inter', sans-serif; background-color: #f8f9fb; }
    .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
    .hidden-state { display: none !important; }
    
    /* Animations */
    .ai-glow { box-shadow: 0 0 20px rgba(0, 82, 204, 0.1); background: linear-gradient(135deg, rgba(255, 255, 255, 1) 0%, rgba(240, 247, 255, 1) 100%); }
    .shimmer { background: linear-gradient(90deg, rgba(255,255,255,0) 0%, rgba(255,255,255,0.4) 50%, rgba(255,255,255,0) 100%); background-size: 200% 100%; }
    @keyframes shimmer { 0% { transform: translateX(-100%); } 100% { transform: translateX(100%); } }
    @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
    .spinner-svg { animation: spin 2s linear infinite; }

    /* Custom scrollbar for policy text */
    .custom-scrollbar::-webkit-scrollbar { width: 6px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background-color: #cbd5e1; border-radius: 20px; }

    /* Markdown content styling */
    .markdown-content strong { color: #1e293b; font-weight: 700; }
    .markdown-content ul { list-style-type: disc; padding-left: 1.5rem; margin-top: 0.5rem; margin-bottom: 1rem; }
    .markdown-content li { margin-bottom: 0.25rem; color: #475569; }
    .markdown-content p { margin-bottom: 1rem; color: #334155; line-height: 1.7; }
    .markdown-content hr { border-color: #e2e8f0; margin: 1.5rem 0; }
  </style>
</head>

<body class="bg-background text-on-surface flex flex-col min-h-screen">
  
  <!-- Navbar -->
  <nav class="bg-white border-b border-slate-200 shadow-sm sticky top-0 z-50">
    <div class="flex justify-between items-center max-w-7xl mx-auto px-6 h-16">
      <a href="/" class="text-xl font-bold tracking-tighter text-blue-700 dark:text-blue-500 font-h2 cursor-pointer">ClaimGuard</a>
      <div class="hidden md:flex items-center gap-4">
        <button class="bg-blue-600 text-white px-5 py-2 rounded-lg text-sm font-medium hover:bg-blue-700 transition-colors">Enterprise Login</button>
      </div>
    </div>
  </nav>

  <!-- ==========================================
       STATE 1: Form View (Initial State)
       ========================================== -->
  <main id="view-form" class="flex-grow max-w-3xl mx-auto py-12 px-6 w-full transition-opacity duration-300">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-slate-900 mb-2">New Claim Submission</h1>
      <p class="text-slate-600">Securely upload your documents for instant AI verification and processing.</p>
    </div>

    <!-- Stepper Indicator -->
    <div class="flex items-center gap-4 mb-8">
      <div class="flex items-center gap-2">
        <span class="w-8 h-8 rounded-full bg-blue-600 text-white flex items-center justify-center font-bold text-sm">1</span>
        <span class="font-bold text-sm text-blue-600">Upload</span>
      </div>
      <div class="h-px bg-slate-300 flex-1"></div>
      <div class="flex items-center gap-2 opacity-40">
        <span class="w-8 h-8 rounded-full bg-slate-200 text-slate-500 flex items-center justify-center font-bold text-sm">2</span>
        <span class="font-bold text-sm">Review</span>
      </div>
    </div>

    <form id="upload-form" class="space-y-6">
      
      <!-- Insurance Info Selection -->
      <div class="bg-white border border-slate-200 rounded-xl p-6 shadow-sm">
        <h4 class="text-lg font-bold text-slate-900 mb-4 flex items-center gap-2">
          <span class="material-symbols-outlined text-blue-600">shield</span>
          Insurance Details
        </h4>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="flex flex-col gap-2">
            <label class="text-sm font-bold text-slate-700">Insurance Category</label>
            <select id="insurance-type" class="w-full bg-slate-50 border border-slate-200 rounded-lg px-4 py-3 text-slate-700 focus:ring-2 focus:ring-blue-600 outline-none">
              <option value="medical" selected>Medical Insurance</option>
              <option value="auto" disabled>Auto Insurance (Coming Soon)</option>
            </select>
          </div>
          <div class="flex flex-col gap-2">
            <label class="text-sm font-bold text-slate-700">Provider & Plan</label>
            <select id="company-plan" class="w-full bg-slate-50 border border-slate-200 rounded-lg px-4 py-3 text-slate-700 focus:ring-2 focus:ring-blue-600 outline-none">
              <optgroup label="Medical Plans">
                <option value="Allianz|OVHC_visitor" selected>Allianz - OVHC (Visitor)</option>
                <option value="Allianz|OVHC_work">Allianz - OVHC (Working)</option>
              </optgroup>
              <optgroup label="Auto Plans">
                Bupa - Premium Health</option>
              </optgroup>
            </select>
          </div>
        </div>
      </div>

      <!-- File Upload Zone -->
      <div class="bg-white border-2 border-dashed border-slate-300 rounded-xl p-8 text-center hover:border-blue-500 transition-colors group relative">
        <div class="flex flex-col items-center">
          <div class="w-16 h-16 bg-blue-50 rounded-full flex items-center justify-center mb-4 group-hover:bg-blue-600 group-hover:text-white transition-colors">
            <span class="material-symbols-outlined text-4xl text-blue-600 group-hover:text-white">cloud_upload</span>
          </div>
          <h3 class="text-lg font-bold text-slate-900 mb-1">Upload Proof Documents</h3>
          <p class="text-sm text-slate-500 mb-4">Support for medical receipts, diagnosis certificates (PDF, JPG, PNG)</p>
          
          <input type="file" id="receipt-image" name="receipt_files" accept="image/*, application/pdf" multiple required class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" />
          
          <button type="button" class="px-6 py-2 border-2 border-blue-600 text-blue-600 font-bold rounded-lg hover:bg-blue-600 hover:text-white transition-colors pointer-events-none">
            Browse Files
          </button>

          <div id="file-list-display" class="w-full flex flex-col gap-2 mt-2 pointer-events-none relative z-20"></div>
        </div>
      </div>

      <!-- Submit Button -->
      <button type="submit" id="submit-btn" class="w-full bg-blue-600 text-white py-4 rounded-xl text-lg font-bold shadow-lg shadow-blue-600/20 hover:bg-blue-700 transition-all flex items-center justify-center gap-2 mt-4">
        <span>Submit for AI Analysis</span>
        <span class="material-symbols-outlined">rocket_launch</span>
      </button>
    </form>
  </main>

  <!-- ==========================================
       STATE 2: AI Analysis (Loading View) 
       ========================================== -->
  <main id="view-loading" class="hidden-state flex-grow flex items-center justify-center px-6 py-12 transition-opacity duration-300">
    <div class="max-w-4xl w-full">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-center">
        <!-- Left: Visual Indicator -->
        <div class="md:col-span-5 flex flex-col items-center justify-center relative">
          <div class="relative flex items-center justify-center">
            <div class="absolute w-48 h-48 bg-blue-600/10 rounded-full blur-3xl"></div>
            <div class="relative w-48 h-48 flex items-center justify-center spinner-svg text-blue-600">
              <svg class="w-full h-full" viewBox="0 0 100 100">
                <circle cx="50" cy="50" fill="transparent" r="40" stroke="#edeef0" stroke-width="8"></circle>
                <circle cx="50" cy="50" fill="transparent" r="40" stroke="currentColor" stroke-dasharray="250" stroke-dashoffset="180" stroke-linecap="round" stroke-width="8"></circle>
              </svg>
            </div>
            <div class="absolute inset-0 flex flex-col items-center justify-center">
              <span class="material-symbols-outlined text-4xl text-blue-600 animate-pulse">memory</span>
            </div>
          </div>
        </div>
        
        <!-- Right: Text Information -->
        <div class="md:col-span-7 space-y-4 text-center md:text-left">
          <div class="inline-flex items-center px-3 py-1 bg-amber-100 text-amber-700 rounded-lg font-bold text-sm">
            <span class="material-symbols-outlined text-[16px] mr-1" style="font-variation-settings: 'FILL' 1;">bolt</span>
            LangGraph Agent Active
          </div>
          <h1 class="text-3xl font-bold text-slate-900">Analyzing Your Claim...</h1>
          <p class="text-slate-600">
            Our Multi-Agent AI is processing your receipts via VLM, extracting diagnosis, and matching medical codes against your specific policy benefits using Qdrant Vector Search.
          </p>
          <div class="p-4 bg-white border border-slate-200 rounded-xl shadow-sm relative overflow-hidden mt-4">
            <div class="flex items-center gap-2 mb-1">
              <span class="material-symbols-outlined text-blue-600 animate-spin">sync</span>
              <span class="font-bold text-slate-900">Cross Validation & Policy Matching</span>
            </div>
            <p class="text-sm text-slate-500">Evaluating cost aggregations and generating final decision...</p>
            <div class="absolute inset-0 shimmer pointer-events-none opacity-20 bg-blue-600/10"></div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <!-- ==========================================
       STATE 3: Analysis Report (Report View) 
       ========================================== -->
  <main id="view-report" class="hidden-state flex-grow max-w-5xl mx-auto w-full px-6 py-12 transition-opacity duration-300">
    <div class="flex flex-col md:flex-row justify-between mb-8 gap-4">
      <div>
        <h1 class="text-3xl font-bold text-slate-900 mb-2">Claim Analysis Complete</h1>
        <p class="text-slate-600">Your documents have been processed and verified by our AI engine.</p>
      </div>
      <div class="inline-flex items-center gap-2 bg-green-100 text-green-700 px-4 py-2 rounded-full self-start">
        <span class="material-symbols-outlined text-[20px]" style="font-variation-settings: 'FILL' 1;">verified</span>
        <span class="font-bold text-sm">Verified</span>
      </div>
    </div>

    <!-- Summary Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <div class="ai-glow p-6 rounded-xl border border-blue-100 flex flex-col justify-between">
        <h3 class="text-xl font-bold text-slate-900 mb-4 flex items-center gap-2">
          <span class="material-symbols-outlined text-blue-600">analytics</span> Executive Summary
        </h3>
        <div class="grid grid-cols-2 gap-4">
          <div class="bg-white/60 p-4 rounded-lg border border-white">
            <p class="text-xs font-bold text-slate-500 uppercase mb-1">Diagnosis</p>
            <p id="res-diagnosis" class="text-lg font-bold text-blue-700">Loading...</p>
          </div>
          <div class="bg-white/60 p-4 rounded-lg border border-white">
            <p class="text-xs font-bold text-slate-500 uppercase mb-1">Total Declared Amount</p>
            <p id="res-cost" class="text-2xl font-bold text-amber-600">Loading...</p>
          </div>
        </div>
      </div>

        <!-- Policy Matched -->
        <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm overflow-hidden flex flex-col h-full">
                <div class="flex items-center justify-between mb-4">
                <h3 class="text-xl font-bold text-slate-900 flex items-center gap-2">
                    <span class="material-symbols-outlined text-slate-500">plagiarism</span>
                    Trigger Clause
                </h3>
                <span class="bg-blue-100 text-blue-700 text-xs font-bold px-3 py-1 rounded-full">RAG Retrieval</span>
                </div>
                <div class="bg-slate-50 border-l-4 border-blue-500 p-4 rounded-r-lg flex-grow overflow-y-auto custom-scrollbar max-h-[150px]">
                <pre id="res-policy" class="text-slate-600 text-sm whitespace-pre-wrap font-mono leading-relaxed">Retrieving policy...</pre>
                </div>
            </div>
            </div>
        
        <!-- AI Decision Details -->
        <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden mb-8">
            <div class="p-6 border-b border-slate-200 bg-gradient-to-r from-slate-50 to-white flex items-center gap-3">
                <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center text-blue-600 shadow-sm">
                <span class="material-symbols-outlined">auto_awesome</span>
                </div>
                <h3 class="text-xl font-bold text-slate-900">GPT-4 Final Decision</h3>
            </div>
            <div class="p-8">
                
                <div id="res-decision" class="markdown-content text-lg">Loading AI Report...</div>
            </div>
            </div>

    
    <!-- Action Bar -->
    <button onclick="location.reload()" class="w-full md:w-auto bg-slate-200 text-slate-700 py-3 px-8 rounded-lg font-bold hover:bg-slate-300 transition-colors">
      Submit Another Claim
    </button>
  </main>

  <!-- Footer -->
  <footer class="bg-slate-50 border-t border-slate-200 py-8 mt-auto">
    <div class="max-w-7xl mx-auto px-8 text-center text-slate-500 text-sm">
      © 2026 ClaimGuard AI (Malone's Demo). Built with LangGraph, FastAPI, and Qdrant.
    </div>
  </footer>

  <!-- ==========================================
       JAVASCRIPT 
       ========================================== -->
  <script is:inline>
    const form = document.getElementById('upload-form');
    const fileInput = document.getElementById('receipt-image');
    
    const viewForm = document.getElementById('view-form');
    const viewLoading = document.getElementById('view-loading');
    const viewReport = document.getElementById('view-report');

    // Listen for file selection and display chosen files
    const fileListDisplay = document.getElementById('file-list-display');
    
    fileInput.addEventListener('change', (e) => {
      // Clear previous file list display
      fileListDisplay.innerHTML = ''; 
      
      const files = e.target.files;
      if (files.length > 0) {
        Array.from(files).forEach(file => {
          
          const fileBadge = document.createElement('div');
          fileBadge.className = 'flex items-center justify-center gap-2 bg-blue-50 text-blue-700 px-3 py-2 rounded-lg text-sm font-medium border border-blue-100 mx-auto w-max max-w-full';
          fileBadge.innerHTML = `
            <span class="material-symbols-outlined text-[18px]">draft</span>
            <span class="truncate max-w-[200px] sm:max-w-xs">${file.name}</span>
          `;
          fileListDisplay.appendChild(fileBadge);
        });
      }
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      if (!fileInput.files.length) {
        alert('Please select at least one document!');
        return;
      }

      const formData = new FormData();
      for (let i = 0; i < fileInput.files.length; i++) {
        formData.append('receipt_files', fileInput.files[i]);
      }

      const combinedValue = document.getElementById('company-plan').value;
      const [selectedCompany, selectedPlan] = combinedValue.split('|');

      formData.append('company', selectedCompany);
      formData.append('plan', selectedPlan);

      viewForm.classList.add('hidden-state');
      viewLoading.classList.remove('hidden-state');
      window.scrollTo({ top: 0, behavior: 'smooth' });

      try {
        const response = await fetch('http://127.0.0.1:8000/api/evaluate-claim', {
          method: 'POST',
          body: formData,
        });

        const data = await response.json();

        if (data.status === 'success') {
          document.getElementById('res-diagnosis').textContent = data.final_diagnosis || 'N/A';
          document.getElementById('res-cost').textContent = `$${data.aggregated_cost || '0.00'}`;
          document.getElementById('res-policy').textContent = data.policy_matched || 'No policy retrieved.';
          document.getElementById('res-decision').textContent = data.decision_report || 'No report generated.';

          const rawReport = data.decision_report || 'No report generated.';
          document.getElementById('res-decision').innerHTML = marked.parse(rawReport);

          viewLoading.classList.add('hidden-state');
          viewReport.classList.remove('hidden-state');
        } else {
          alert('Error: ' + (data.message || 'Unknown Error'));
          viewLoading.classList.add('hidden-state');
          viewForm.classList.remove('hidden-state');
        }
      } catch (error) {
        console.error('API Error:', error);
        alert('Cannot connect to backend server. Is FastAPI running?');
        viewLoading.classList.add('hidden-state');
        viewForm.classList.remove('hidden-state');
      }
    });
  </script>
</body>
</html>